# ===========================
# AI Agent Ephemeral Files
# Session-specific files that should NOT be forked/templated.
# Templates (_TEMPLATE.*) ARE tracked; generated content is NOT.
# ===========================
.ai/sessions/*
!.ai/sessions/_TEMPLATE.md
.ai/todos/*
!.ai/todos/_TEMPLATE.todo.md
.ai/plans/*
!.ai/plans/_TEMPLATE.architecture.md
!.ai/plans/_TEMPLATE.plan.md
!.ai/plans/impl/
.ai/plans/impl/*
!.ai/plans/impl/_TEMPLATE.impl.md
.ai/specs/*
.ai/previews/*
.ai/trace.md

# Feedback (project-specific, regenerated per-project)
# README and PUSH_NOTE template are tracked; generated content is not.
feedback/*
!feedback/README.md
!feedback/PUSH_NOTE.md

# Archived playbooks (migrated to .github/skills/ and .github/instructions/)
docs/playbooks/_archive/

# AI Agent Reports (project-specific, regenerated per-project)
# Template is tracked; generated reports are not.
docs/*_REPORT.md
docs/MIGRATION_LOG.md
!docs/_TEMPLATE.report.md
!docs/_TEMPLATE.retrospective-report.md
!docs/_TEMPLATE.review-report.md

# ===========================
# Empty project directories
# (keep these entries so git tracks the folders)
# Agents: ADD new folders here when you create them
# ===========================
!src/utils/
!src/services/
!src/models/
!src/config/
!tests/
!scripts/
!docs/
!docs/discoveries/
!docs/files/
!.ai/
!.ai/sessions/
!.ai/plans/
!.ai/todos/
!.ai/specs/
!.ai/previews/
!.github/instructions/
